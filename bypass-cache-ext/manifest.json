{
    "manifest_version": 3,
    "name": "CDN Cache Bypass (Bookmark)",
    "version": "1.1",
    "description": "ブックマークから開いたサイトにキャッシュバスターを付与し、CDNキャッシュを回避します。",
    "permissions": [
        "webNavigation",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    }
}